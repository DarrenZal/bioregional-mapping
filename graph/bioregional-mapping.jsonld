      "name": "joint-commitment",
      "description": "Spore primitive — multi-party-simultaneous commitment (spore:ADR-0050). Workshop-as-Joint-Commitment is paradigm-case."
    },
    {
      "@id": "bioregional-mapping.concept.layer",
      "@type": "skos:Concept",
      "name": "layer",
      "description": "A mapping-practice layer (relational, cultural, ecological, economic, governance, geospatial); one of six headings in the multi-layer rubric."
    },
    {
      "@id": "bioregional-mapping.concept.membrane",
