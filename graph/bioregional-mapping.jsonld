      "name": "membrane",
      "description": "Spore primitive — permeable boundary with self-produced or text-authoritative production-mode (spore:ADR-0062, ADR-0053). Mapping layers as membranes."
    },
    {
      "@id": "bioregional-mapping.concept.practitioner",
      "@type": "skos:Concept",
