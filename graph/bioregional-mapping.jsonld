      "@id": "bioregional-mapping.concept.bioregion",
      "@type": "skos:Concept",
      "name": "bioregion",
      "description": "Place-attached coordination scope (Salish Sea, Cascadia, Sierra Nevada de Santa Marta, etc.). Load-bearing per spore.positioning.agentic-bioregionalism."
    },
    {
      "@id": "bioregional-mapping.concept.ceremony",
      "@type": "skos:Concept",
      "name": "ceremony",
      "description": "Practice form at cultural layer that gates certain forms of knowledge transmission and witnessing."
    },
    {
      "@id": "bioregional-mapping.concept.commitment",
      "@type": "skos:Concept",
      "name": "commitment",
      "description": "Spore primitive (basic, non-joint form). Mapping outputs surface commitments at the economic layer; flow into BKC's CommitmentPool patterns."
    },
    {
      "@id": "bioregional-mapping.concept.consent",
      "@type": "skos:Concept",
      "name": "consent",
      "description": "Free, prior, informed consent (FPIC); load-bearing at cultural layer for Indigenous-knowledge intake."
    },
    {
      "@id": "bioregional-mapping.concept.documentation",
      "@type": "skos:Concept",
      "name": "documentation",
      "description": "Workshop artifact capture (photos, flipcharts, evaluation forms, narrative pieces); raw material for Story of Place and downstream regeneration strategies."
    },
    {
      "@id": "bioregional-mapping.concept.evidence",
      "@type": "skos:Concept",
      "name": "evidence",
      "description": "Spore verb — claim-supporting artifact. Mapping outputs become evidence for downstream claims (entity resolution, commitments, regeneration strategy)."
    },
    {
      "@id": "bioregional-mapping.concept.facilitation",
      "@type": "skos:Concept",
      "name": "facilitation",
      "description": "Workshop convening labor; care + maintenance + translation labour at the workshop layer (per spore.maintenance-economics)."
    },
    {
      "@id": "bioregional-mapping.concept.field",
      "@type": "skos:Concept",
      "name": "field",
      "description": "Spore primitive — coordination substrate with rule-stack (operational/collective-choice/constitutional layers per spore:ADR-0046). Story of Place is a Field manifestation."
    },
    {
      "@id": "bioregional-mapping.concept.field-guide",
      "@type": "skos:Concept",
      "name": "field-guide",
      "description": "A training-the-trainers manual (e.g., RC Bioregional Mapping Field Guide) that transmits methodology across cohorts; reproduction-continuity artifact."
    },
    {
      "@id": "bioregional-mapping.concept.holon",
      "@type": "skos:Concept",
      "name": "holon",
      "description": "Spore primitive — irreducible coordination unit. Bioregional holons nest (sub-watershed → watershed → ecoregion)."
    },
    {
      "@id": "bioregional-mapping.concept.indigenous-led-governance",
      "@type": "skos:Concept",
      "name": "indigenous-led-governance",
      "description": "Governance by Indigenous nations and protocols, prior to and across colonial jurisdictions. Per BioKulture engineering frame."
    },
    {
      "@id": "bioregional-mapping.concept.intent",
      "@type": "skos:Concept",
      "name": "intent",
      "description": "Spore primitive — directional motivation surfacing in commitments."
    },
